<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.ehcache.org/v3"
        xsi:schemaLocation="http://www.ehcache.org/v3 http://www.ehcache.org/schema/ehcache-core-3.0.xsd">

    <!-- L2 Cache Configuration - Persistent database cache -->
    <cache alias="l2Employees">
        <expiry>
            <ttl unit="minutes">60</ttl>
        </expiry>
        <heap unit="entries">2000</heap>
    </cache>

    <cache alias="l2EmployeeById">
        <expiry>
            <ttl unit="hours">2</ttl>
        </expiry>
        <heap unit="entries">1000</heap>
    </cache>

    <cache alias="l2EmployeesByDepartment">
        <expiry>
            <ttl unit="minutes">60</ttl>
        </expiry>
        <heap unit="entries">500</heap>
    </cache>

    <cache alias="l2EmployeeByEmail">
        <expiry>
            <ttl unit="hours">2</ttl>
        </expiry>
        <heap unit="entries">1000</heap>
    </cache>

    <cache alias="l2SearchResults">
        <expiry>
            <ttl unit="minutes">30</ttl>
        </expiry>
        <heap unit="entries">1000</heap>
    </cache>

    <cache alias="l2Addresses">
        <expiry>
            <ttl unit="minutes">60</ttl>
        </expiry>
        <heap unit="entries">3000</heap>
    </cache>

    <cache alias="l2Statistics">
        <expiry>
            <ttl unit="minutes">10</ttl>
        </expiry>
        <heap unit="entries">50</heap>
    </cache>

</config>
